{
    "mcpServers": {
        "laravel-boost": {
            "command": "docker",
            "args": [
                "compose",
                "-f",
                "docker-compose.local.yml",
                "--env-file",
                ".env.docker",
                "exec",
                "-T",
                "php",
                "php",
                "artisan",
                "boost:mcp"
            ]
        }
    }
}
